# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a long random string: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# 1. Enable 2-Step Verification on your Google account
# 2. Go to myaccount.google.com → Security → App passwords
# 3. Create an app password named "AjoFlow" and paste the 16-char code below
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM=AjoFlow <your@gmail.com>

# ── App URL ───────────────────────────────────────────────────────────────────
# In production set this to your Vercel frontend URL
CLIENT_URL=https://your-app.vercel.app
